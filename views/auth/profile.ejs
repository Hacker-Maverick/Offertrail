<%- locals.extraStyles = '<link rel="stylesheet" href="/styles/dashboard.css">' %>

<div class="dashboard-header page-fade-in">
    <div class="dashboard-title">
        <h1>Profile Settings</h1>
    </div>
</div>

<%- include('../partials/messages') %>

<div class="card page-fade-in" style="max-width: 600px; padding: 32px; animation-delay: 50ms;">
    <h2 style="font-size: 1.125rem; margin-bottom: 24px; border-bottom: 1px solid var(--border-subtle); padding-bottom: 12px;">Update Password</h2>
    
    <form action="/auth/profile" method="POST" style="display: flex; flex-direction: column; gap: 16px;">
        <div>
            <label class="label" for="currentPassword">Current Password</label>
            <input type="password" id="currentPassword" name="currentPassword" class="input" required>
        </div>
        <div>
            <label class="label" for="newPassword">New Password</label>
            <input type="password" id="newPassword" name="newPassword" class="input" required>
        </div>
        <div style="margin-top: 8px;">
            <button type="submit" class="btn btn--primary">Save Changes</button>
        </div>
    </form>
</div>
