<%- locals.extraStyles = '<link rel="stylesheet" href="/styles/auth.css">' %>

<div class="auth-layout">
    <!-- Left Branding Panel -->
    <div class="auth-panel-branding">
        <div class="auth-bg-pattern"></div>
        <div class="auth-bg-glow"></div>
        
        <a href="/" class="auth-logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            OfferTrail
        </a>
    </div>

    <!-- Right Form Panel -->
    <div class="auth-panel-form">
        <div class="auth-form-container page-fade-in">
            <h1 class="auth-title">Set New Password</h1>
            <p class="auth-subtitle">Enter your new password below.</p>

            <%- include('../partials/messages') %>

            <form action="/auth/reset-password/<%= token %>" method="POST">
                <div class="form-group">
                    <label class="label" for="password">New Password</label>
                    <input type="password" id="password" name="password" class="input" required>
                </div>
                
                <div class="form-group">
                    <label class="label" for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" class="input" required>
                </div>

                <button type="submit" class="btn btn--primary auth-btn-submit">Reset Password</button>
            </form>
        </div>
    </div>
</div>
