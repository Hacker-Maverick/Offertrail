<link rel="stylesheet" href="/styles/auth.css">

<div class="auth-layout">
    <!-- Left Branding Panel -->
    <div class="auth-panel-branding">
        <div class="auth-bg-pattern"></div>
        <div class="auth-bg-glow"></div>
        
        <a href="/" class="auth-logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            OfferTrail
        </a>

        <div class="auth-testimonial-wrapper">
            <div class="auth-testimonial">
                <p class="auth-quote">"I used to track everything in Notion. OfferTrail gave me actual analytics and clarity."</p>
                <p class="auth-author">&mdash; Rahul M., CS Student</p>
            </div>
        </div>
    </div>

    <!-- Right Form Panel -->
    <div class="auth-panel-form">
        <div class="auth-form-container page-fade-in">
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-subtitle">Log in to your OfferTrail dashboard.</p>

            <% if(locals.success_msg && success_msg.length > 0) { %>
                <div class="alert-global alert-global--success">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <%= success_msg %>
                </div>
            <% } %>

            <% if(locals.error_msg && error_msg.length > 0) { %>
                <div class="alert-global alert-global--error">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    <%= error_msg %>
                </div>
            <% } %>

            <% if(locals.error && error.length > 0) { %>
                <div class="alert-global alert-global--error">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    <%= error %>
                </div>
            <% } %>

            <form action="/auth/login" method="POST">
                <div class="form-group">
                    <label class="label" for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="input" required placeholder="you@example.com" autocomplete="email">
                </div>
                
                <div class="form-group">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                        <label class="label" for="password" style="margin-bottom: 0;">Password</label>
                        <a href="/auth/forgot-password" style="font-size: 0.8125rem; color: var(--accent); font-weight: 500;">Forgot password?</a>
                    </div>
                    <input type="password" id="password" name="password" class="input" required placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;">
                </div>

                <button type="submit" class="btn btn--primary auth-btn-submit">Sign In</button>
            </form>

            <div class="auth-links">
                Don't have an account? <a href="/auth/signup">Sign up</a>
            </div>
        </div>
    </div>
</div>
